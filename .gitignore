# NetElixIQ AI — .gitignore
# ─────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
.env
!.env.example

# ── Testing ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.xml

# ── Database ──────────────────────────────────────────────
# Generated at runtime — do NOT commit
netelixiq.db
*.sqlite
*.sqlite3

# ── Cache ─────────────────────────────────────────────────
.cache/

# ── Frontend ──────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Root package-lock (orphan) ────────────────────────────
/package-lock.json
/package.json

# ── Session pickles (auto-generated per user session) ─────
pickle/pipeline_*.pkl
# model.pkl IS committed — it is the hackathon submission artifact
!pickle/model.pkl

# ── IDEs & OS ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Output predictions (generated, not committed) ─────────
output/
