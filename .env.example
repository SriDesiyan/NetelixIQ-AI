# NetElixIQ AI — Environment Configuration
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=NetElixIQ AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
DEMO_MODE=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./netelixiq.db

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Without a key, the platform uses intelligent demo responses.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ── ML Settings ───────────────────────────────────────────────────────────────
DEFAULT_FORECAST_HORIZON=30
MONTE_CARLO_SIMULATIONS=2000
MAX_UPLOAD_SIZE_MB=50

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_DIR=.cache
CACHE_TTL_SECONDS=1800

# ── Data (must match data/sample directory) ───────────────────────────────────
DEMO_DATA_DIR=data/sample
